  "publicApiSurface": [
    "POST /auth-start - Initiate Gmail OAuth flow",
    "GET /auth-callback - Handle OAuth callback",
    "POST /gmail-webhook - Process incoming Gmail notifications",
    "POST /process-document - Extract transactions from uploaded files",
    "POST /seed-emails - Import historical emails",
    "POST /renew-watches - Renew Gmail watch subscriptions",
    "gmailService.connectGmail() - Start OAuth connection",
    "gmailService.disconnectGmail() - Remove Gmail connection",
    "uploadDocumentForAnalysis() - Upload and process documents",
    "NotificationsService - Manage user notifications"
